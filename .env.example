# ============================================================================
# FinOpt Environment Variables
# Copy this file to .env and fill in your values
# ============================================================================

# ----------------------------------------------------------------------------
# Supabase Configuration
# Get these from: https://supabase.com/dashboard/project/YOUR_PROJECT/settings/api
# ----------------------------------------------------------------------------

# Project URL (e.g., https://abcdefghijklmnop.supabase.co)
SUPABASE_URL=https://your-project.supabase.co

# Anon/Public key - safe to use in frontend (has RLS restrictions)
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Service Role key - ONLY for backend, bypasses RLS
# KEEP THIS SECRET - never expose in frontend or commit to git
SUPABASE_SERVICE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ----------------------------------------------------------------------------
# API Configuration
# ----------------------------------------------------------------------------

# Environment: development, staging, production
ENVIRONMENT=development

# API host and port (for local development)
API_HOST=0.0.0.0
API_PORT=8000

# CORS allowed origins (comma-separated)
# In production, set to your frontend URL
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# ----------------------------------------------------------------------------
# Frontend Configuration (Vite uses VITE_ prefix)
# ----------------------------------------------------------------------------

# Supabase URL for frontend
VITE_SUPABASE_URL=https://your-project.supabase.co

# Supabase anon key for frontend (same as SUPABASE_ANON_KEY)
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Python API URL (for calling compute endpoints)
VITE_API_URL=http://localhost:8000

# ----------------------------------------------------------------------------
# Optional: Logging and Debug
# ----------------------------------------------------------------------------

# Log level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# Enable debug mode (more verbose errors)
FINOPT_DEBUG=false
